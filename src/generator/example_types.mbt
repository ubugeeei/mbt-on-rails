///|
/// Distinguishes the kinds of dynamic route parameters supported by page modules.
pub(all) enum RouteParamKind {
  Param
  CatchAll
  OptionalCatchAll
}

///|
/// Describes one typed route parameter extracted from a route pattern.
pub struct RouteParamSpec {
  raw_name : String
  field_name : String
  kind : RouteParamKind
}

///|
/// Describes one typed route helper extracted from a page module.
pub struct RouteHelperSpec {
  route_name : String
  route_path : String
  params : Array[RouteParamSpec]
}

///|
/// Describes one generated view template helper.
pub struct TemplateHelperSpec {
  function_name : String
  source_path : String
}

///|
/// Describes one typed server action input field.
pub struct ActionFieldSpec {
  raw_name : String
  field_name : String
  type_name : String
}

///|
/// Describes one typed server action helper extracted from frontend code.
pub struct ActionHelperSpec {
  action_name : String
  route : String
  input_fields : Array[ActionFieldSpec]
  output_type : String
}

///|
/// Builds typed template helper metadata from a list of `.mbtv` files.
pub fn template_helpers(
  views_dir~ : String,
  template_paths~ : Array[String],
) -> Array[TemplateHelperSpec] {
  let helpers : Array[TemplateHelperSpec] = []
  let normalized_views_dir = normalize_relative_path(views_dir)
  let prefix = normalized_views_dir + "/"
  let sorted_template_paths : Array[String] = template_paths.map(
    normalize_relative_path,
  )
  sorted_template_paths.sort_by((left, right) => left.compare(right))
  for template_path in sorted_template_paths {
    let relative_path = if template_path.has_prefix(prefix) {
      String::unsafe_substring(
        template_path,
        start=prefix.length(),
        end=template_path.length(),
      )
    } else {
      template_path
    }
    let without_suffix = strip_suffix(relative_path, ".mbtv")
    let joined_parts = without_suffix
      .split("/")
      .map(fn(part) { part.to_string() })
      .collect()
      .join("_")
    helpers.push({
      function_name: "view_" + snake_identifier(joined_parts),
      source_path: template_path,
    })
  }
  helpers
}

///|
/// Extracts typed route helpers from `page_module(...)` declarations in frontend code.
pub fn route_helpers(frontend_source : String) -> Array[RouteHelperSpec] {
  let helpers : Array[RouteHelperSpec] = []
  for call_body in page_module_calls(frontend_source) {
    let arguments = split_top_level_arguments(call_body)
    match extract_route_helper(arguments) {
      Some(helper) => helpers.push(helper)
      None => ()
    }
  }
  helpers
}

///|
/// Extracts typed action helpers from `server_action(...)` declarations.
pub fn server_action_helpers(
  frontend_source : String,
) -> Array[ActionHelperSpec] {
  let helpers : Array[ActionHelperSpec] = []
  for call_body in server_action_calls(frontend_source) {
    let arguments = split_top_level_arguments(call_body)
    match extract_action_helper(arguments) {
      Some(helper) => helpers.push(helper)
      None => ()
    }
  }
  helpers
}

///|
/// Generates a typed helper source file for template paths, routes, and actions.
pub fn generate_example_types_source(
  views_dir~ : String,
  template_paths~ : Array[String],
  frontend_source~ : String,
  generator_name? : String = "cmd/generate_example_types",
) -> String {
  let lines : Array[String] = []
  lines.push("// Generated by " + generator_name + ". DO NOT EDIT.")
  lines.push("")

  for helper in template_helpers(views_dir~, template_paths~) {
    push_template_helper(lines, helper)
  }

  for helper in route_helpers(frontend_source) {
    push_route_helper(lines, helper)
  }

  for helper in server_action_helpers(frontend_source) {
    push_action_helper(lines, helper)
  }

  lines.join("\n")
}

///|
fn push_template_helper(
  lines : Array[String],
  helper : TemplateHelperSpec,
) -> Unit {
  lines.push("///|")
  lines.push("pub fn " + helper.function_name + "() -> @support.MbtvPath {")
  lines.push("  @support.mbtv_path(\"" + helper.source_path + "\")")
  lines.push("}")
  lines.push("")
}

///|
fn push_route_helper(lines : Array[String], helper : RouteHelperSpec) -> Unit {
  let route_function_name = snake_identifier(helper.route_name)
  if helper.params.is_empty() {
    lines.push("///|")
    lines.push("pub fn " + route_function_name + "_path() -> String {")
    lines.push("  \"" + helper.route_path + "\"")
    lines.push("}")
    lines.push("")
    lines.push("///|")
    lines.push("pub fn " + route_function_name + "_route_pattern() -> String {")
    lines.push("  \"" + helper.route_path + "\"")
    lines.push("}")
    lines.push("")
    lines.push("///|")
    lines.push(
      "pub fn " +
      route_function_name +
      "_route_params() -> Array[(String, String)] {",
    )
    lines.push("  []")
    lines.push("}")
    lines.push("")
    return
  }

  let struct_name = camel_identifier(helper.route_name) + "RouteParams"
  lines.push("///|")
  lines.push("pub struct " + struct_name + " {")
  for param in helper.params {
    let field_type = match param.kind {
      OptionalCatchAll => "String?"
      _ => "String"
    }
    lines.push("  " + param.field_name + " : " + field_type)
  }
  lines.push("}")
  lines.push("")
  lines.push("///|")
  lines.push(
    "pub fn " +
    route_function_name +
    "_route_params(" +
    helper.params.map(render_route_param_constructor_arg).join(", ") +
    ") -> " +
    struct_name +
    " {",
  )
  lines.push(
    "  { " + helper.params.map(param => param.field_name).join(", ") + ", }",
  )
  lines.push("}")
  lines.push("")
  lines.push("///|")
  lines.push(
    "pub fn " +
    struct_name +
    "::entries(self : " +
    struct_name +
    ") -> Array[(String, String)] {",
  )
  lines.push("  let entries : Array[(String, String)] = []")
  for param in helper.params {
    match param.kind {
      OptionalCatchAll => {
        lines.push("  match self." + param.field_name + " {")
        lines.push(
          "    Some(value) => entries.push((\"" + param.raw_name + "\", value))",
        )
        lines.push("    None => ()")
        lines.push("  }")
      }
      _ =>
        lines.push(
          "  entries.push((\"" +
          param.raw_name +
          "\", self." +
          param.field_name +
          "))",
        )
    }
  }
  lines.push("  entries")
  lines.push("}")
  lines.push("")
  lines.push("///|")
  lines.push(
    "pub fn " +
    route_function_name +
    "_path(params : " +
    struct_name +
    ") -> String {",
  )
  lines.push("  " + render_path_expression(helper.route_path, "params"))
  lines.push("}")
  lines.push("")
  lines.push("///|")
  lines.push("pub fn " + route_function_name + "_route_pattern() -> String {")
  lines.push("  \"" + helper.route_path + "\"")
  lines.push("}")
  lines.push("")
}

///|
fn push_action_helper(lines : Array[String], helper : ActionHelperSpec) -> Unit {
  let action_function_name = snake_identifier(helper.action_name)
  lines.push("///|")
  lines.push("pub fn " + action_function_name + "_action_name() -> String {")
  lines.push("  \"" + helper.action_name + "\"")
  lines.push("}")
  lines.push("")
  lines.push("///|")
  lines.push("pub fn " + action_function_name + "_action_route() -> String {")
  lines.push("  \"" + helper.route + "\"")
  lines.push("}")
  lines.push("")
  lines.push("///|")
  lines.push(
    "pub fn " + action_function_name + "_action_output_type() -> String {",
  )
  lines.push("  \"" + helper.output_type + "\"")
  lines.push("}")
  lines.push("")

  if helper.input_fields.is_empty() {
    lines.push("///|")
    lines.push(
      "pub fn " +
      action_function_name +
      "_action_entries() -> Array[(String, String)] {",
    )
    lines.push("  []")
    lines.push("}")
    lines.push("")
    return
  }

  let struct_name = camel_identifier(helper.action_name) + "ActionInput"
  lines.push("///|")
  lines.push("pub struct " + struct_name + " {")
  for field in helper.input_fields {
    lines.push(
      "  " + field.field_name + " : " + normalized_action_type(field.type_name),
    )
  }
  lines.push("}")
  lines.push("")
  lines.push("///|")
  lines.push(
    "pub fn " +
    action_function_name +
    "_action_input(" +
    helper.input_fields.map(render_action_constructor_arg).join(", ") +
    ") -> " +
    struct_name +
    " {",
  )
  lines.push(
    "  { " +
    helper.input_fields.map(field => field.field_name).join(", ") +
    ", }",
  )
  lines.push("}")
  lines.push("")
  lines.push("///|")
  lines.push(
    "pub fn " +
    struct_name +
    "::entries(self : " +
    struct_name +
    ") -> Array[(String, String)] {",
  )
  lines.push("  let entries : Array[(String, String)] = []")
  for field in helper.input_fields {
    push_action_entry_lines(lines, field)
  }
  lines.push("  entries")
  lines.push("}")
  lines.push("")
  lines.push("///|")
  lines.push(
    "pub fn " +
    action_function_name +
    "_action_entries(input : " +
    struct_name +
    ") -> Array[(String, String)] {",
  )
  lines.push("  input.entries()")
  lines.push("}")
  lines.push("")
}

///|
fn render_action_constructor_arg(field : ActionFieldSpec) -> String {
  field.field_name + "~ : " + normalized_action_type(field.type_name)
}

///|
fn push_action_entry_lines(
  lines : Array[String],
  field : ActionFieldSpec,
) -> Unit {
  let normalized_type = normalized_action_type(field.type_name)
  match normalized_type {
    "String" =>
      lines.push(
        "  entries.push((\"" +
        field.raw_name +
        "\", self." +
        field.field_name +
        "))",
      )
    "Int" =>
      lines.push(
        "  entries.push((\"" +
        field.raw_name +
        "\", self." +
        field.field_name +
        ".to_string()))",
      )
    "Bool" =>
      lines.push(
        "  entries.push((\"" +
        field.raw_name +
        "\", if self." +
        field.field_name +
        " { \"true\" } else { \"false\" }))",
      )
    "String?" => {
      lines.push("  match self." + field.field_name + " {")
      lines.push(
        "    Some(value) => entries.push((\"" + field.raw_name + "\", value))",
      )
      lines.push("    None => ()")
      lines.push("  }")
    }
    "Int?" => {
      lines.push("  match self." + field.field_name + " {")
      lines.push(
        "    Some(value) => entries.push((\"" +
        field.raw_name +
        "\", value.to_string()))",
      )
      lines.push("    None => ()")
      lines.push("  }")
    }
    "Bool?" => {
      lines.push("  match self." + field.field_name + " {")
      lines.push(
        "    Some(value) => entries.push((\"" +
        field.raw_name +
        "\", if value { \"true\" } else { \"false\" }))",
      )
      lines.push("    None => ()")
      lines.push("  }")
    }
    _ =>
      lines.push(
        "  entries.push((\"" +
        field.raw_name +
        "\", self." +
        field.field_name +
        "))",
      )
  }
}

///|
fn normalized_action_type(type_name : String) -> String {
  match type_name.trim().to_string() {
    "String" => "String"
    "Int" => "Int"
    "Integer" => "Int"
    "Bool" => "Bool"
    "Boolean" => "Bool"
    "String?" => "String?"
    "Int?" => "Int?"
    "Integer?" => "Int?"
    "Bool?" => "Bool?"
    "Boolean?" => "Bool?"
    other => if other.has_suffix("?") { "String?" } else { "String" }
  }
}

///|
fn render_route_param_constructor_arg(param : RouteParamSpec) -> String {
  let field_type = match param.kind {
    OptionalCatchAll => "String?"
    _ => "String"
  }
  param.field_name + "~ : " + field_type
}

///|
fn extract_route_helper(arguments : Array[String]) -> RouteHelperSpec? {
  let route_name = match find_labeled_string_argument(arguments, "route_name") {
    Some(value) => Some(value)
    None => positional_string_argument(arguments, 0)
  }
  let route_path = match find_labeled_string_argument(arguments, "route_path") {
    Some(value) => Some(value)
    None => positional_string_argument(arguments, 1)
  }

  match (route_name, route_path) {
    (Some(name), Some(path)) =>
      Some({ route_name: name, route_path: path, params: route_params(path) })
    _ => None
  }
}

///|
fn extract_action_helper(arguments : Array[String]) -> ActionHelperSpec? {
  let action_name = match find_labeled_string_argument(arguments, "name") {
    Some(value) => Some(value)
    None => positional_string_argument(arguments, 0)
  }
  let route = match find_labeled_string_argument(arguments, "route") {
    Some(value) => Some(value)
    None => positional_string_argument(arguments, 1)
  }
  let output_type = match
    find_labeled_string_argument(arguments, "output_type") {
    Some(value) => Some(value)
    None => positional_string_argument(arguments, 3)
  }
  let input_fields = match find_labeled_argument(arguments, "input_fields") {
    Some(value) => parse_action_input_fields(value)
    None =>
      match positional_argument(arguments, 2) {
        Some(value) => parse_action_input_fields(value)
        None => []
      }
  }

  match (action_name, route, output_type) {
    (Some(name), Some(path), Some(output_type)) =>
      Some({ action_name: name, route: path, input_fields, output_type })
    _ => None
  }
}

///|
fn route_params(route_path : String) -> Array[RouteParamSpec] {
  let params : Array[RouteParamSpec] = []
  for segment in @support.split_path(route_path) {
    if segment.has_prefix("[[...") && segment.has_suffix("]]") {
      let raw_name = String::unsafe_substring(
        segment,
        start=5,
        end=segment.length() - 2,
      )
      params.push({
        raw_name,
        field_name: snake_identifier(raw_name),
        kind: OptionalCatchAll,
      })
    } else if segment.has_prefix("[...") && segment.has_suffix("]") {
      let raw_name = String::unsafe_substring(
        segment,
        start=4,
        end=segment.length() - 1,
      )
      params.push({
        raw_name,
        field_name: snake_identifier(raw_name),
        kind: CatchAll,
      })
    } else if segment.has_prefix("[") && segment.has_suffix("]") {
      let raw_name = String::unsafe_substring(
        segment,
        start=1,
        end=segment.length() - 1,
      )
      params.push({
        raw_name,
        field_name: snake_identifier(raw_name),
        kind: Param,
      })
    }
  }
  params
}

///|
fn parse_action_input_fields(source : String) -> Array[ActionFieldSpec] {
  let trimmed = source.trim().to_string()
  if trimmed.length() < 2 ||
    unsafe_char_at(trimmed, 0) != '[' ||
    unsafe_char_at(trimmed, trimmed.length() - 1) != ']' {
    return []
  }

  let inner = trimmed_slice(trimmed, 1, trimmed.length() - 1)
  if inner.length() == 0 {
    return []
  }

  let fields : Array[ActionFieldSpec] = []
  for field_source in split_top_level_arguments(inner) {
    match parse_action_input_field(field_source) {
      Some(field) => fields.push(field)
      None => ()
    }
  }
  fields
}

///|
fn parse_action_input_field(source : String) -> ActionFieldSpec? {
  let trimmed = source.trim().to_string()
  if trimmed.length() < 2 ||
    unsafe_char_at(trimmed, 0) != '(' ||
    unsafe_char_at(trimmed, trimmed.length() - 1) != ')' {
    return None
  }

  let arguments = split_top_level_arguments(
    trimmed_slice(trimmed, 1, trimmed.length() - 1),
  )
  let raw_name = positional_string_argument(arguments, 0)
  let type_name = positional_string_argument(arguments, 1)
  match (raw_name, type_name) {
    (Some(raw_name), Some(type_name)) =>
      Some({ raw_name, field_name: snake_identifier(raw_name), type_name })
    _ => None
  }
}

///|
fn render_path_expression(route_path : String, params_name : String) -> String {
  let pieces : Array[String] = []
  for segment in @support.split_path(route_path) {
    if segment.has_prefix("[[...") && segment.has_suffix("]]") {
      let raw_name = String::unsafe_substring(
        segment,
        start=5,
        end=segment.length() - 2,
      )
      let field_name = snake_identifier(raw_name)
      pieces.push(
        "match " +
        params_name +
        "." +
        field_name +
        " { Some(value) => if value.length() == 0 { \"\" } else { \"/\" + value } None => \"\" }",
      )
    } else if segment.has_prefix("[...") && segment.has_suffix("]") {
      let raw_name = String::unsafe_substring(
        segment,
        start=4,
        end=segment.length() - 1,
      )
      pieces.push("\"/\" + " + params_name + "." + snake_identifier(raw_name))
    } else if segment.has_prefix("[") && segment.has_suffix("]") {
      let raw_name = String::unsafe_substring(
        segment,
        start=1,
        end=segment.length() - 1,
      )
      pieces.push("\"/\" + " + params_name + "." + snake_identifier(raw_name))
    } else {
      pieces.push("\"/" + segment + "\"")
    }
  }
  if pieces.is_empty() {
    "\"/\""
  } else {
    pieces.join(" + ")
  }
}

///|
fn page_module_calls(source : String) -> Array[String] {
  let calls : Array[String] = []
  let target = "page_module"
  collect_function_calls(source, target, calls)
  calls
}

///|
fn server_action_calls(source : String) -> Array[String] {
  let calls : Array[String] = []
  let target = "server_action"
  collect_function_calls(source, target, calls)
  calls
}

///|
fn collect_function_calls(
  source : String,
  target : String,
  calls : Array[String],
) -> Unit {
  let mut index = 0
  while index < source.length() {
    if has_identifier_at(source, index, target) {
      let open_paren_index = skip_whitespace(source, index + target.length())
      if open_paren_index < source.length() &&
        unsafe_char_at(source, open_paren_index) == '(' {
        match balanced_parenthesized_content(source, open_paren_index) {
          Some((call_body, end_index)) => {
            calls.push(call_body)
            index = end_index + 1
            continue
          }
          None => ()
        }
      }
    }
    index += 1
  }
}

///|
fn split_top_level_arguments(source : String) -> Array[String] {
  let arguments : Array[String] = []
  let mut start = 0
  let mut index = 0
  let mut paren_depth = 0
  let mut bracket_depth = 0
  let mut brace_depth = 0
  let mut in_string = false
  let mut quote = '\u0000'
  let mut escaped = false
  while index < source.length() {
    let ch = unsafe_char_at(source, index)
    if in_string {
      if escaped {
        escaped = false
      } else if ch == '\\' {
        escaped = true
      } else if ch == quote {
        in_string = false
      }
      index += 1
      continue
    }

    match ch {
      '"' | '\'' => {
        in_string = true
        quote = ch
      }
      '(' => paren_depth += 1
      ')' => paren_depth -= 1
      '[' => bracket_depth += 1
      ']' => bracket_depth -= 1
      '{' => brace_depth += 1
      '}' => brace_depth -= 1
      ',' =>
        if paren_depth == 0 && bracket_depth == 0 && brace_depth == 0 {
          arguments.push(trimmed_slice(source, start, index))
          start = index + 1
        }
      _ => ()
    }
    index += 1
  }

  let tail = trimmed_slice(source, start, source.length())
  if tail.length() > 0 {
    arguments.push(tail)
  }
  arguments
}

///|
fn find_labeled_string_argument(
  arguments : Array[String],
  label : String,
) -> String? {
  match find_labeled_argument(arguments, label) {
    Some(argument_value) => decode_string_literal(argument_value)
    None => None
  }
}

///|
fn positional_string_argument(
  arguments : Array[String],
  index : Int,
) -> String? {
  match positional_argument(arguments, index) {
    Some(argument) => decode_string_literal(argument)
    None => None
  }
}

///|
fn find_labeled_argument(arguments : Array[String], label : String) -> String? {
  for argument in arguments {
    match argument.find("=") {
      Some(separator) => {
        let argument_label = trimmed_slice(argument, 0, separator)
        if argument_label == label {
          return Some(trimmed_slice(argument, separator + 1, argument.length()))
        }
      }
      None => ()
    }
  }
  None
}

///|
fn positional_argument(arguments : Array[String], index : Int) -> String? {
  if index < 0 || index >= arguments.length() {
    return None
  }
  Some(arguments[index])
}

///|
fn decode_string_literal(source : String) -> String? {
  let trimmed = source.trim().to_string()
  if trimmed.length() < 2 ||
    unsafe_char_at(trimmed, 0) != '"' ||
    unsafe_char_at(trimmed, trimmed.length() - 1) != '"' {
    return None
  }

  let builder = StringBuilder::new()
  let mut index = 1
  while index < trimmed.length() - 1 {
    let ch = unsafe_char_at(trimmed, index)
    if ch == '\\' && index + 1 < trimmed.length() - 1 {
      let escaped = unsafe_char_at(trimmed, index + 1)
      match escaped {
        '"' => builder.write_char('"')
        '\\' => builder.write_char('\\')
        'n' => builder.write_char('\n')
        'r' => builder.write_char('\r')
        't' => builder.write_char('\t')
        other => builder.write_char(other)
      }
      index += 2
      continue
    }
    builder.write_char(ch)
    index += 1
  }
  Some(builder.to_string())
}

///|
fn balanced_parenthesized_content(
  source : String,
  open_paren_index : Int,
) -> (String, Int)? {
  let mut depth = 1
  let mut index = open_paren_index + 1
  let mut in_string = false
  let mut quote = '\u0000'
  let mut escaped = false
  while index < source.length() {
    let ch = unsafe_char_at(source, index)
    if in_string {
      if escaped {
        escaped = false
      } else if ch == '\\' {
        escaped = true
      } else if ch == quote {
        in_string = false
      }
      index += 1
      continue
    }

    match ch {
      '"' | '\'' => {
        in_string = true
        quote = ch
      }
      '(' => depth += 1
      ')' => {
        depth -= 1
        if depth == 0 {
          return Some(
            (
              String::unsafe_substring(
                source,
                start=open_paren_index + 1,
                end=index,
              ),
              index,
            ),
          )
        }
      }
      _ => ()
    }
    index += 1
  }
  None
}

///|
fn has_identifier_at(source : String, index : Int, target : String) -> Bool {
  if index < 0 || index + target.length() > source.length() {
    return false
  }
  let slice = String::unsafe_substring(
    source,
    start=index,
    end=index + target.length(),
  )
  if slice != target {
    return false
  }

  let has_identifier_prefix = if index == 0 {
    false
  } else {
    is_identifier_char(unsafe_char_at(source, index - 1))
  }
  let suffix_index = index + target.length()
  let has_identifier_suffix = if suffix_index >= source.length() {
    false
  } else {
    is_identifier_char(unsafe_char_at(source, suffix_index))
  }
  not(has_identifier_prefix || has_identifier_suffix)
}

///|
fn skip_whitespace(source : String, index : Int) -> Int {
  let mut cursor = index
  while cursor < source.length() &&
        is_whitespace(unsafe_char_at(source, cursor)) {
    cursor += 1
  }
  cursor
}

///|
fn trimmed_slice(source : String, start : Int, end : Int) -> String {
  String::unsafe_substring(source, start~, end~).trim().to_string()
}

///|
fn normalize_relative_path(path : String) -> String {
  let mut normalized = path.trim().to_string()
  while normalized.has_prefix("./") {
    normalized = String::unsafe_substring(
      normalized,
      start=2,
      end=normalized.length(),
    )
  }
  normalized
}

///|
fn strip_suffix(source : String, suffix : String) -> String {
  if source.has_suffix(suffix) {
    String::unsafe_substring(
      source,
      start=0,
      end=source.length() - suffix.length(),
    )
  } else {
    source
  }
}

///|
fn snake_identifier(source : String) -> String {
  let builder = StringBuilder::new()
  let mut wrote_underscore = false
  let mut wrote_content = false
  for ch in source.to_array() {
    if is_ascii_alphanumeric(ch) {
      if ch >= 'A' && ch <= 'Z' {
        match (ch.to_int() + 32).to_char() {
          Some(lower) => builder.write_char(lower)
          None => builder.write_char(ch)
        }
      } else {
        builder.write_char(ch)
      }
      wrote_underscore = false
      wrote_content = true
    } else if not(wrote_underscore) && wrote_content {
      builder.write_char('_')
      wrote_underscore = true
    }
  }
  let cleaned = trim_trailing_underscores(builder.to_string())
  if cleaned.length() == 0 {
    return "generated"
  }
  if is_ascii_digit(unsafe_char_at(cleaned, 0)) {
    "_" + cleaned
  } else {
    cleaned
  }
}

///|
fn trim_trailing_underscores(source : String) -> String {
  let mut end_index = source.length()
  while end_index > 0 && unsafe_char_at(source, end_index - 1) == '_' {
    end_index -= 1
  }
  String::unsafe_substring(source, start=0, end=end_index)
}

///|
fn camel_identifier(source : String) -> String {
  let normalized = snake_identifier(source)
  if normalized.length() == 0 {
    return "Generated"
  }
  let builder = StringBuilder::new()
  let mut upper_next = true
  for ch in normalized.to_array() {
    if ch == '_' {
      upper_next = true
      continue
    }
    if upper_next && ch >= 'a' && ch <= 'z' {
      match (ch.to_int() - 32).to_char() {
        Some(upper) => builder.write_char(upper)
        None => builder.write_char(ch)
      }
    } else {
      builder.write_char(ch)
    }
    upper_next = false
  }
  let generated = builder.to_string()
  if generated.length() == 0 {
    "Generated"
  } else if is_ascii_digit(unsafe_char_at(generated, 0)) {
    "Generated" + generated
  } else {
    generated
  }
}

///|
fn unsafe_char_at(source : String, index : Int) -> Char {
  source.unsafe_get(index).unsafe_to_char()
}

///|
fn is_identifier_char(ch : Char) -> Bool {
  is_ascii_alphanumeric(ch) || ch == '_'
}

///|
fn is_ascii_alphanumeric(ch : Char) -> Bool {
  (ch >= 'a' && ch <= 'z') || (ch >= 'A' && ch <= 'Z') || is_ascii_digit(ch)
}

///|
fn is_ascii_digit(ch : Char) -> Bool {
  ch >= '0' && ch <= '9'
}

///|
fn is_whitespace(ch : Char) -> Bool {
  ch == ' ' || ch == '\n' || ch == '\r' || ch == '\t'
}
