///|
test "generate example types source includes typed view helpers and labeled route params" {
  let source = generate_example_types_source(
    views_dir="examples/demo_blog/views",
    template_paths=[
      "examples/demo_blog/views/pages/home.mbtv", "examples/demo_blog/views/components/post_form.mbtv",
    ],
    frontend_source="fn demo() {\n" +
      "  @view.page_module(\n" +
      "    route_name=\"posts_edit\",\n" +
      "    route_path=\"/posts/[id]/edit\",\n" +
      "    file_path=view_pages_posts_edit(),\n" +
      "    title=\"Edit Post\",\n" +
      "    component=demo_posts_edit_page_component(),\n" +
      "  )\n" +
      "}\n",
  )

  assert_true(
    source.contains("Generated by cmd/generate_example_types. DO NOT EDIT."),
  )
  assert_true(
    source.contains("pub fn view_components_post_form() -> @support.MbtvPath"),
  )
  assert_true(source.contains("pub fn view_pages_home() -> @support.MbtvPath"))
  assert_true(source.contains("pub struct PostsEditRouteParams"))
  assert_true(
    source.contains(
      "pub fn posts_edit_route_params(id~ : String) -> PostsEditRouteParams",
    ),
  )
  assert_true(
    source.contains(
      "pub fn posts_edit_path(params : PostsEditRouteParams) -> String",
    ),
  )
}

///|
test "route helpers support legacy positional page module declarations" {
  let helpers = route_helpers(
    "fn legacy() {\n" +
    "  page_module(\"posts_show\", \"/posts/[id]\", some_path(), \"Post\", some_component())\n" +
    "}\n",
  )

  assert_eq(helpers.length(), 1)
  assert_eq(helpers[0].route_name, "posts_show")
  assert_eq(helpers[0].route_path, "/posts/[id]")
  assert_eq(helpers[0].params.length(), 1)
  assert_eq(helpers[0].params[0].field_name, "id")
}
